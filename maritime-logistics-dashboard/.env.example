# Environment Variables — Maritime Logistics Dashboard
# Copy this file to .env.local for local development

# ─── AISStream.io — Free Real-Time Vessel Tracking ───────────────────────────
# Sign up at https://aisstream.io (free, no credit card)
# Without this key, the map will display demo data
VITE_AISSTREAM_API_KEY=your_aisstream_api_key_here

# ─── OpenSky Network ─────────────────────────────────────────────────────────
# No key needed — OpenSky is completely free and open
# Live flight data fetches automatically from https://opensky-network.org
# (no configuration required)
